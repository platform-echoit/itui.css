{
  "name": "@echoit/itui.css",
  "description": "",
  "version": "1.0.5",
  "publishConfig": {
    "access": "public"
  },
  "author": "echoit <echoit.dev.04@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/platform-echoit/itui.css.git"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "style": "./dist/index.css"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:generate": "tsx scripts/test-generate.ts",
    "build": "pnpm build:js",
    "dev": "tsup --watch",
    "build:js": "tsup",
    "build:css": "cpy src/styles/global.css dist/styles/global.css",
    "check:package": "pnpm pack && npm publish --dry-run",
    "publish:beta": "pnpm build && npm publish --tag beta --access public",
    "publish:latest": "pnpm build && npm publish --access public"
  },
  "type": "module",
  "keywords": [],
  "license": "ISC",
  "packageManager": "pnpm@10.23.0",
  "dependencies": {
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-popover": "1.1.15",
    "@tailwindcss/vite": "4.2.3",
    "@types/react": "19.2.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.12.0",
    "react": "19.2.5",
    "sonner": "2.0.7",
    "tailwind-merge": "2.6.0",
    "tailwindcss": "4.2.3",
    "tslib": "^2"
  },
  "devDependencies": {
    "@types/node": "22.15.3",
    "cpy-cli": "^7.0.0",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  }
}
